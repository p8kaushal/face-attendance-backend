PORT=3000
SESSION_SECRET=your-session-secret-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# PostgreSQL (get free DB from neon.tech or supabase)
DATABASE_URL=postgresql://user:password@host:5432/face_attendance

# Admin emails and usernames (comma separated)
ADMIN_USERS=your-email@gmail.com,your-github-username
